# ── Bot token from @BotFather ─────────────────────────────────────────────────
LINKTAXI_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ── Your own Telegram user ID (message @userinfobot to find it) ───────────────
LINKTAXI_ADMIN_ID=YOUR_USER_ID_HERE

# ── Telegram API credentials from https://my.telegram.org/apps ───────────────
LINKTAXI_API_ID=YOUR_API_ID_HERE
LINKTAXI_API_HASH=your_api_hash_here
